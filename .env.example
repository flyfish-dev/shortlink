# 最小化配置：首次启动会进入安装向导，并把运行时配置保存到 DATA_DIR/app-config.json。
APP_ADDR=:8080
DATA_DIR=/app/data

# 反向代理/HTTPS 部署时再调整：
TRUST_PROXY=false
COOKIE_SECURE=false

# 可选。留空会自动生成并持久化；生产建议首次部署后不要随意更换。
APP_SECRET=

SESSION_TTL_HOURS=87600
UPLOAD_MAX_MB=8

# Optional GitHub OAuth login.
# Callback URL: https://your-domain.example/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
